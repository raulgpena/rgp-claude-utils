##
## Azure Static Web App Module - Input Variables
## Author: Raul Peña (rpena@shokworks.io)
##
## Purpose: Configurable parameters for Azure Static Web App
## Used for deploying Angular/React/Vue frontend applications
##

##=============================================================================
## REQUIRED INFRASTRUCTURE VARIABLES
##=============================================================================

variable "resource_group_name" {
  description = "Name of the resource group"
  type        = string
}

variable "location" {
  description = "Azure region for resources"
  type        = string
}

variable "environment" {
  description = "Environment name (dev/staging/prod)"
  type        = string
}

variable "resource_prefix" {
  description = "Prefix for resource naming"
  type        = string
}

variable "tags" {
  description = "Tags to apply to all resources"
  type        = map(string)
}

##=============================================================================
## STATIC WEB APP CONFIGURATION
##=============================================================================

variable "app_name" {
  description = "Name of the Static Web App"
  type        = string
  default     = "frontend"
}

variable "sku_tier" {
  description = "SKU tier (Free or Standard)"
  type        = string
  default     = "Free"

  validation {
    condition     = contains(["Free", "Standard"], var.sku_tier)
    error_message = "SKU tier must be either Free or Standard."
  }
}

variable "sku_size" {
  description = "SKU size (Free or Standard)"
  type        = string
  default     = "Free"

  validation {
    condition     = contains(["Free", "Standard"], var.sku_size)
    error_message = "SKU size must be either Free or Standard."
  }
}

##=============================================================================
## GITHUB REPOSITORY CONFIGURATION
##=============================================================================

variable "github_repo_url" {
  description = "GitHub repository URL (e.g., https://github.com/owner/repo)"
  type        = string
}

variable "github_token" {
  description = "GitHub personal access token for authentication"
  type        = string
  sensitive   = true
}

variable "github_branch" {
  description = "Branch to deploy from (e.g., main, develop)"
  type        = string
  default     = "develop"
}

variable "app_location" {
  description = "Location of the application source code"
  type        = string
  default     = "/"
}

variable "output_location" {
  description = "Build output directory (e.g., dist, dist/my-app, build)"
  type        = string
  default     = "dist"
}

variable "build_command" {
  description = "Build command (e.g., npm run build, ng build, yarn build)"
  type        = string
  default     = "npm run build"
}

##=============================================================================
## ENVIRONMENT VARIABLES & API CONFIGURATION
##=============================================================================

variable "api_endpoint" {
  description = "Backend API endpoint URL"
  type        = string
}

variable "environment_variables" {
  description = "Environment variables for the Static Web App"
  type        = map(string)
  default     = {}
}

variable "api_key" {
  description = "Optional API key for backend authentication"
  type        = string
  sensitive   = true
  default     = ""
}
