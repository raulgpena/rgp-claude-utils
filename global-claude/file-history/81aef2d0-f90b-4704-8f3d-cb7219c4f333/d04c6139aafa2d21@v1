##
## Description: Global Shared Resources - Outputs
## Purpose: Export critical information from global resources for use by environments
## Usage: These outputs are referenced by environment modules and CI/CD pipelines
## Author: Raul Peña (rpena@shokworks.io)
##
## Output Strategy:
## - All outputs are prefixed with "shared_" to indicate global/shared resources
## - Sensitive outputs (passwords, keys) should use sensitive = true
## - Outputs enable cross-stack references between global and environments

##=============================================================================
## RESOURCE GROUP OUTPUTS
##=============================================================================
## Shared resource group information used by all environments
## 
## The shared resource group contains all global resources (container registry, etc)
## accessible by dev, staging, and prod environments

output "shared_resource_group_name" {

  value       = azurerm_resource_group.shared_rg.name
  description = "Name of the shared resource group containing all global resources"

  # Output usage:
  # - Reference in environment deployments to locate shared resources
  # - Used in Azure CLI commands to filter and query resources
  # - Example: az resource list --resource-group <this-value>
}

output "shared_resource_group_id" {

  value       = azurerm_resource_group.shared_rg.id
  description = "Full Azure Resource ID (ARM ID) of the shared resource group"

  # Output usage:
  # - ARM ID format: /subscriptions/{subId}/resourceGroups/{rgName}
  # - Used for precise resource references and RBAC assignments
  # - Required for Azure CLI and SDK operations requiring full resource paths
}


##=============================================================================
## CONTAINER REGISTRY OUTPUTS - CONNECTION & ACCESS
##=============================================================================
## Critical information for accessing the shared container registry
## Used by all environments to push/pull Docker images

output "shared_container_registry_name" {

  value       = module.shared_container_registry.registry_name
  description = "Name of the shared Azure Container Registry (ACR)"

  # Output usage:
  # - Docker login: docker login <login_server_value>
  # - Azure CLI: az acr login --name <this-value>
  # - Display in: README files, documentation, deployment guides
  # - Example value: ixdnashared
}

output "shared_container_registry_login_server" {

  value       = module.shared_container_registry.login_server
  description = "Login server URL for the shared Container Registry (FQDN)"

  # Output usage:
  # - Docker image pulling: docker pull <this-value>/repository:tag
  # - Docker image pushing: docker tag myapp:v1 <this-value>/myapp:v1
  # - Kubernetes image pulls: image: <this-value>/repo:tag
  # - Example value: ixdnashared.azurecr.io
  # - Used in container definitions across all environments
}

output "shared_container_registry_id" {

  value       = module.shared_container_registry.registry_id
  description = "Full Azure Resource ID (ARM ID) of the shared Container Registry"

  # Output usage:
  # - RBAC role assignments for service principals
  # - Access control and permissions configuration
  # - Resource monitoring and policy enforcement
  # - Azure CLI commands requiring resource ID
}


##=============================================================================
## CONTAINER REGISTRY OUTPUTS - REPOSITORY & IMAGE MANAGEMENT
##=============================================================================
## Information about repositories and how to push images to the registry

output "shared_container_registry_repositories" {

  value       = module.shared_container_registry.repositories
  description = "List of repository names configured in the shared Container Registry"

  # Output usage:
  # - Displays available repositories: ["lexxi", "data-cleansing", "portal"]
  # - Used for documentation and reference
  # - Helps teams understand what images can be stored
  # - Example output: ["lexxi", "data-cleansing", "portal"]
}

output "shared_container_registry_push_commands" {

  value       = module.shared_container_registry.push_commands
  description = "Ready-to-use Docker push commands for each repository in shared registry"

  # Output usage:
  # - Copy/paste commands for CI/CD pipelines
  # - Quick reference for developers pushing images
  # - Maps each repository to its push command
  # - Example format:
  #   {
  #     "lexxi" = "docker push ixdnashared.azurecr.io/lexxi:TAG"
  #     "data-cleansing" = "docker push ixdnashared.azurecr.io/data-cleansing:TAG"
  #     "portal" = "docker push ixdnashared.azurecr.io/portal:TAG"
  #   }
  # 
  # Usage example:
  #   make output ENV=global
  #   # Copy the push command and replace TAG with your version
}

output "shared_container_registry_defender_enabled" {

  value       = module.shared_container_registry.defender_enabled
  description = "Whether Microsoft Defender for Container Registries is enabled (subscription-level pricing tier)"

  # Output usage:
  # - Confirms Defender is actively scanning all pushed images
  # - Used in verification scripts and security dashboards
  # - Required for Azure Security Center integration
  # - Example value: true
}


##=============================================================================
## CONTAINER REGISTRY OUTPUTS - MICROSOFT DEFENDER CONFIGURATION
##=============================================================================
## Information about security scanning and vulnerability assessment

output "shared_container_registry_sku" {

  value       = module.shared_container_registry.registry_sku
  description = "SKU (pricing tier) of the shared Container Registry"

  # Output usage:
  # - Confirms production-grade features are available
  # - Standard SKU includes: Defender support, webhooks, geo-replication prep
  # - Example value: Standard

  # SKU comparison:
  # - Basic: Limited features, suitable for development only
  # - Standard: Recommended for production (500GB storage, Defender support)
  # - Premium: Advanced features (geo-replication, private endpoints)
}


##=============================================================================
## ACCESSING THESE OUTPUTS
##=============================================================================
## How to view and use these outputs in different contexts:
##
## 1. View all outputs:
##    make output ENV=global
##    terraform output
##
## 2. View specific output:
##    make output ENV=global | grep shared_container_registry_login_server
##    terraform output shared_container_registry_login_server
##
## 3. Use in shell scripts:
##    REGISTRY=$(terraform output -raw shared_container_registry_login_server)
##    docker login $REGISTRY
##
## 4. Use in CI/CD pipelines:
##    - Store outputs in .tfvars or secrets
##    - Reference in GitHub Actions, GitLab CI, etc.
##    - Pass to deployment scripts
##
## 5. Reference in environment deployments:
##    - data.terraform_remote_state.global.outputs.shared_container_registry_login_server
##    - (requires proper Terraform backend configuration)
