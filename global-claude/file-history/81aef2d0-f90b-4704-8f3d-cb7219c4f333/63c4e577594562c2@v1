## Prod Environment - Locals
## This file defines environment-specific configurations for the prod environment
## All resources in prod will be tagged and named using these locals
## Author: Raul Peña (rpena@shokworks.io)

locals {

  # Resource naming conventions
  # These locals generate consistent Azure resource names following the pattern:
  # - Resource group: rg-{project}-lexxi-{environment}
  # - Resource prefix: {company}-{project}-{environment} (used in all resource names)
  resource_group_name = "rg-${var.company_name}-${var.project_name}-${var.environment}"
  resource_prefix     = "${var.company_name}-${var.project_name}-${var.environment}"

  # Environment-specific configuration
  # Contains all settings that differ from staging and prod environments
  env_config = {

    # General compute & storage configuration
    enable_backup      = false # Backups disabled for dev environment
    replica_count      = 1     # Single replica for cost optimization
    instance_size      = "B1"  # Burstable tier for development workloads
    auto_shutdown      = true  # Enable auto-shutdown to reduce costs
    log_retention_days = 30    # 30-day retention for dev logs
    backup_retention   = 7     # 7-day backup retention period

    # Add other service-specific configurations here as needed
  }

  # Resource tags applied to all created resources
  # These help with cost allocation, ownership tracking, and automation
  tags = {

    Environment = var.environment  # Environment identifier (dev/staging/prod)
    Project     = var.project_name # Project name for cost tracking
    Company     = var.company_name # Company/team identifier
    ManagedBy   = "Terraform"      # Indicates resources are IaC-managed
    CreatedDate = "2026"           # Year of resource creation
  }

