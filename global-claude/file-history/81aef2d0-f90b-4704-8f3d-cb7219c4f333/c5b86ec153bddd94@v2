##
## Purpose: Configurable parameters for storage infrastructure
## Enables flexible deployment across dev and production
##

##=============================================================================
## REQUIRED INFRASTRUCTURE VARIABLES
##=============================================================================
## Basic Azure identifiers for resource placement

variable "resource_group_name" {
  description = "Name of the resource group"
  type        = string
}

variable "location" {
  description = "Azure region for resources"
  type        = string
}

variable "environment" {
  description = "Environment name"
  type        = string
}

##=============================================================================
## BACKUP & RETENTION CONFIGURATION
##=============================================================================
## Settings for data protection and compliance

variable "enable_backup" {
  description = "Enable backup for resources"
  type        = bool
  default     = false
}

variable "backup_retention_days" {
  description = "Backup retention period in days"
  type        = number
  default     = 7
}

variable "log_retention_days" {
  description = "Log retention period in days"
  type        = number
  default     = 30
}

variable "tags" {
  description = "Tags to apply to all resources"
  type        = map(string)
}

variable "resource_prefix" {
  description = "Prefix for resource naming"
  type        = string
}
