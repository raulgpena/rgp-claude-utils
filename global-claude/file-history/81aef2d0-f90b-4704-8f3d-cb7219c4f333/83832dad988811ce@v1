##
## Application Gateway Module - Input Variables
## Author: Raul Peña (rpena@shokworks.io)
##
## Purpose: Configurable parameters for Azure Application Gateway with WAF
## Designed for cost-optimized development deployments
##

##=============================================================================
## REQUIRED INFRASTRUCTURE VARIABLES
##=============================================================================

variable "resource_group_name" {

  description = "Name of the resource group"
  type        = string
}

variable "location" {

  description = "Azure region for resources"
  type        = string
}

variable "environment" {

  description = "Environment name (dev/staging/prod)"
  type        = string
}

variable "resource_prefix" {

  description = "Prefix for resource naming"
  type        = string
}

variable "tags" {

  description = "Tags to apply to all resources"
  type        = map(string)
}


##=============================================================================
## NETWORK CONFIGURATION
##=============================================================================

variable "virtual_network_id" {
  
  description = "ID of the virtual network"
  type        = string
}

variable "vnet_address_space" {

  description = "VNet address space in CIDR notation (to extract gateway subnet)"
  type        = list(string)
}

variable "gateway_subnet_address_prefix" {

  description = "Address prefix for Application Gateway subnet (/26 minimum)"
  type        = string
  default     = "10.0.1.0/26"
}


##=============================================================================
## APPLICATION GATEWAY CONFIGURATION
##=============================================================================

variable "app_gateway_sku_tier" {

  description = "SKU tier (Standard_v2 for production-like, Basic for minimal cost)"
  type        = string
  default     = "Standard_v2"
}

variable "app_gateway_sku_capacity" {

  description = "Number of instances (2 minimum for Standard_v2, 1 for Basic)"
  type        = number
  default     = 2
}


##=============================================================================
## BACKEND CONFIGURATION
##=============================================================================

variable "backend_fqdn" {

  description = "FQDN of the Container App backend"
  type        = string
}

variable "backend_port" {

  description = "Port of the backend application"
  type        = number
  default     = 443
}

variable "backend_protocol" {

  description = "Protocol for backend communication (Http or Https)"
  type        = string
  default     = "Https"
  
  validation {
    condition     = contains(["Http", "Https"], var.backend_protocol)
    error_message = "Backend protocol must be either Http or Https."
  }
}


##=============================================================================
## WAF CONFIGURATION
##=============================================================================

variable "enable_waf" {

  description = "Enable Web Application Firewall (WAF)"
  type        = bool
  default     = true
}

variable "waf_mode" {

  description = "WAF mode (Detection logs threats, Prevention blocks them)"
  type        = string
  default     = "Detection"
  
  validation {
    condition     = contains(["Detection", "Prevention"], var.waf_mode)
    error_message = "WAF mode must be either Detection or Prevention."
  }
}

variable "waf_rule_set_version" {

  description = "WAF rule set version (e.g., 3.1, 3.2)"
  type        = string
  default     = "3.2"
}


##=============================================================================
## SSL/TLS CONFIGURATION
##=============================================================================

variable "enable_https" {

  description = "Enable HTTPS listener (uses Azure-managed certificate for dev)"
  type        = bool
  default     = true
}

variable "http_listener_port" {

  description = "HTTP listener port"
  type        = number
  default     = 80
}

variable "https_listener_port" {
    
  description = "HTTPS listener port"
  type        = number
  default     = 443
}
