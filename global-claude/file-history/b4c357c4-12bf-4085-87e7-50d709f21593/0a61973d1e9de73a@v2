"""Evaluation script for the Lexxi Clinical Discussion agent.

Runs the discussion generator against a fixed dataset of concern + SNP inputs,
scores each output with an LLM judge (discussion_quality), and logs the
results as an MLflow Evaluation Run under the 'lexxi-evaluation' experiment.

Usage (from the project root):
    uv run python scripts/evaluation/evaluate_discussion.py

    EVAL_RUN_NAME="discussion-prompt-v2" uv run python scripts/evaluation/evaluate_discussion.py

What appears in MLflow after the run:
    Experiments → lexxi-evaluation → <run>
      Metrics tab : discussion_quality/mean, discussion_quality/p90, ...
      Evaluation  : table with input / output / score + rationale per case
"""

from __future__ import annotations

import asyncio
import json
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2]))

import mlflow
from dotenv import load_dotenv

from app.ai.agent_clinical_discussion import generate_all_discussions
from app.ai.mlflow_tracker import configure as configure_mlflow
from app.core.config import get_settings
from scripts.evaluation.judges import discussion_quality

load_dotenv()

# ── Setup ─────────────────────────────────────────────────────────────────────

settings = get_settings()

configure_mlflow(
    enabled=settings.mlflow.mlflow_enabled,
    tracking_uri=settings.mlflow.mlflow_tracking_uri,
    experiment_name="lexxi-evaluation",
    username=settings.mlflow.mlflow_username,
    password=settings.mlflow.mlflow_password,
    tracing_enabled=False,
)

RUN_NAME = os.environ.get("EVAL_RUN_NAME", "clinical-discussion-eval")
DATA_PATH = Path(__file__).parent / "data" / "discussion_dataset.json"

# ── Predict function ──────────────────────────────────────────────────────────


async def _run_agent(concern_name: str, snps: list[dict]) -> str:
    results = await generate_all_discussions(
        [{"concern_name": concern_name, "snps": snps}]
    )
    return results[0].get("text", "") if results else ""


def predict_fn(inputs: dict) -> str:
    """Called by mlflow.genai.evaluate() once per row with the inputs dict."""
    return asyncio.run(
        _run_agent(
            concern_name=inputs["concern_name"],
            snps=inputs["snps"],
        )
    )


# ── Run evaluation ────────────────────────────────────────────────────────────


def main() -> None:
    records = json.loads(DATA_PATH.read_text())

    data = [
        {
            "inputs": {
                "concern_name": r["concern_name"],
                "snps": r["snps"],
            },
        }
        for r in records
    ]

    print(f"Running evaluation: '{RUN_NAME}' — {len(data)} test cases")
    print(f"Tracking server : {settings.mlflow.mlflow_tracking_uri}")
    print(f"Experiment      : lexxi-evaluation\n")

    with mlflow.start_run(run_name=RUN_NAME):
        mlflow.log_params({
            "dataset": DATA_PATH.name,
            "num_test_cases": len(data),
            "model": "gpt-4o",
            "temperature": 0.7,
            "agent": "clinical_discussion",
        })

        results = mlflow.genai.evaluate(
            data=data,
            scorers=[discussion_quality],
            predict_fn=predict_fn,
        )

    print("\n── Aggregate metrics ────────────────────────────────────────────")
    for metric, value in sorted(results.metrics.items()):
        print(f"  {metric:<45} {value:.4f}")

    print("\n── Per-case scores ──────────────────────────────────────────────")
    table = results.tables.get("eval_results_table")
    if table is not None:
        score_col = next(
            (c for c in table.columns if "discussion_quality" in c and "score" in c),
            None,
        )
        rationale_col = next(
            (c for c in table.columns if "discussion_quality" in c and "rationale" in c),
            None,
        )
        cols = [c for c in ["inputs", score_col, rationale_col] if c]
        if cols:
            print(table[cols].to_string(index=False))


if __name__ == "__main__":
    main()
