"""Evaluation script for the Lexxi Clinical Chat agent.

Runs the clinical chat agent against a fixed dataset of clinician questions
paired with genomic concern/SNP contexts, scores each output with an LLM
judge (chat_helpfulness), and logs the results under 'lexxi-evaluation'.

Usage (from the project root):
    uv run python scripts/evaluation/evaluate_chat.py

    EVAL_RUN_NAME="chat-prompt-v2" uv run python scripts/evaluation/evaluate_chat.py

What appears in MLflow after the run:
    Experiments → lexxi-evaluation → <run>
      Metrics tab : chat_helpfulness/mean, chat_helpfulness/p90, ...
      Evaluation  : table with input / output / score + rationale per case
"""

from __future__ import annotations

import asyncio
import json
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2]))

import mlflow
from dotenv import load_dotenv

from app.ai.agent_clinical_chat import run_clinical_chat_stream
from app.ai.mlflow_tracker import configure as configure_mlflow
from app.core.config import get_settings
from scripts.evaluation.judges import chat_helpfulness

load_dotenv()

# ── Setup ─────────────────────────────────────────────────────────────────────

settings = get_settings()

configure_mlflow(
    enabled=settings.mlflow.mlflow_enabled,
    tracking_uri=settings.mlflow.mlflow_tracking_uri,
    experiment_name="lexxi-evaluation",
    username=settings.mlflow.mlflow_username,
    password=settings.mlflow.mlflow_password,
    tracing_enabled=False,
)

RUN_NAME = os.environ.get("EVAL_RUN_NAME", "clinical-chat-eval")
DATA_PATH = Path(__file__).parent / "data" / "chat_dataset.json"

# ── Predict function ──────────────────────────────────────────────────────────


async def _run_agent(messages: list[dict], concerns: list[dict]) -> str:
    async for event in run_clinical_chat_stream(messages=messages, concerns=concerns):
        if event["type"] == "done":
            return event.get("final_text", "")
        if event["type"] == "error":
            return f"[error] {event.get('content', 'unknown error')}"
    return ""


def predict_fn(inputs: dict) -> str:
    """Called by mlflow.genai.evaluate() once per row with the inputs dict."""
    return asyncio.run(
        _run_agent(
            messages=inputs["messages"],
            concerns=inputs["concerns"],
        )
    )


# ── Run evaluation ────────────────────────────────────────────────────────────


def main() -> None:
    records = json.loads(DATA_PATH.read_text())

    data = [
        {
            "inputs": {
                "messages": r["messages"],
                "concerns": r["concerns"],
            },
        }
        for r in records
    ]

    print(f"Running evaluation: '{RUN_NAME}' — {len(data)} test cases")
    print(f"Tracking server : {settings.mlflow.mlflow_tracking_uri}")
    print(f"Experiment      : lexxi-evaluation\n")

    with mlflow.start_run(run_name=RUN_NAME):
        mlflow.log_params({
            "dataset": DATA_PATH.name,
            "num_test_cases": len(data),
            "model": "gpt-4o",
            "temperature": 0,
            "agent": "clinical_chat",
        })

        results = mlflow.genai.evaluate(
            data=data,
            scorers=[chat_helpfulness],
            predict_fn=predict_fn,
        )

    print("\n── Aggregate metrics ────────────────────────────────────────────")
    for metric, value in sorted(results.metrics.items()):
        print(f"  {metric:<45} {value:.4f}")

    print("\n── Per-case scores ──────────────────────────────────────────────")
    table = results.tables.get("eval_results_table")
    if table is not None:
        score_col = next(
            (c for c in table.columns if "chat_helpfulness" in c and "score" in c),
            None,
        )
        rationale_col = next(
            (c for c in table.columns if "chat_helpfulness" in c and "rationale" in c),
            None,
        )
        cols = [c for c in ["inputs", score_col, rationale_col] if c]
        if cols:
            print(table[cols].to_string(index=False))


if __name__ == "__main__":
    main()
