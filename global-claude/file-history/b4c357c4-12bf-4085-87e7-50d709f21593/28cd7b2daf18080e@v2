"""Shared LLM-as-judge scorer definitions for Lexxi agent evaluations.

Each scorer uses GPT-4o to evaluate agent outputs and returns a Feedback
object with a numeric score (1–5) and a short rationale.

Compatible with the MLflow 3.x ``mlflow.genai.evaluate()`` API.

Scorers:
  concerns_accuracy  — did the extractor identify the right concerns?
  discussion_quality — is the clinical discussion clinically sound?
  chat_helpfulness   — is the chat response relevant and helpful?
"""

from __future__ import annotations

from mlflow.entities import Feedback
from mlflow.genai.scorers import scorer
from openai import OpenAI


def _llm_score(prompt: str) -> tuple[int, str]:
    """Call GPT-4o with a grading prompt and parse 'SCORE: N\\nRATIONALE: ...'."""
    client = OpenAI()
    response = client.chat.completions.create(
        model="gpt-4o",
        messages=[{"role": "user", "content": prompt}],
        temperature=0,
        max_tokens=200,
    )
    text = response.choices[0].message.content.strip()

    score = 3  # fallback
    rationale = text
    for line in text.splitlines():
        if line.upper().startswith("SCORE:"):
            try:
                score = int(line.split(":", 1)[1].strip()[0])
            except (ValueError, IndexError):
                pass
        if line.upper().startswith("RATIONALE:"):
            rationale = line.split(":", 1)[1].strip()

    return max(1, min(5, score)), rationale


# ── Concerns Extractor ────────────────────────────────────────────────────────


@scorer(name="concerns_accuracy", aggregations=["mean", "variance", "p90"])
def concerns_accuracy(inputs: dict, outputs: str, expectations: dict) -> Feedback:
    """Score how accurately the agent extracted clinical concerns.

    Requires an ``expectations`` dict with key ``expected_concerns`` (comma-
    separated string of expected official concern names).
    """
    expected = expectations.get("expected_concerns", "(not provided)")
    clinician_input = inputs.get("messages", [{}])[-1].get("content", str(inputs))

    prompt = f"""\
You are evaluating an AI that extracts clinical concerns from a clinician's patient description.

Clinician input:
{clinician_input}

AI extracted concerns (JSON):
{outputs}

Expected concerns:
{expected}

Score the extraction accuracy from 1 to 5:
5 — All expected concerns correctly identified; no hallucinated or invalid concern names.
4 — Most expected concerns identified; at most one minor omission or inexact name.
3 — About half of the expected concerns identified; some omissions or 1-2 related but inexact names.
2 — Few correct concerns; many omissions or several hallucinated names.
1 — Output is empty, completely wrong, or contains only hallucinated concern names.

Reply in this exact format:
SCORE: <number>
RATIONALE: <one sentence>"""

    score, rationale = _llm_score(prompt)
    return Feedback(name="concerns_accuracy", value=score, rationale=rationale)


# ── Clinical Discussion ────────────────────────────────────────────────────────


@scorer(name="discussion_quality", aggregations=["mean", "variance", "p90"])
def discussion_quality(inputs: dict, outputs: str) -> Feedback:
    """Score the clinical quality of a generated genomics discussion."""
    concern_name = inputs.get("concern_name", "unknown")

    prompt = f"""\
You are evaluating a clinical genomics discussion generated by an AI for a clinician.

Concern being discussed: {concern_name}

Generated discussion:
{outputs}

Score the clinical quality from 1 to 5:
5 — Clinically accurate, professional tone, directly addresses the genomic variants referenced
    (as SNP-X placeholders), provides actionable clinical insights, appropriate length.
4 — Good quality with minor gaps; addresses most variants but may miss one insight.
3 — Adequate but noticeably generic; does not fully leverage the specific variant data.
2 — Poor clinical quality; vague, off-topic for the concern, or missing substantive genomic insights.
1 — Inappropriate, potentially harmful, completely off-topic, or failed to generate content.

Reply in this exact format:
SCORE: <number>
RATIONALE: <one sentence>"""

    score, rationale = _llm_score(prompt)
    return Feedback(name="discussion_quality", value=score, rationale=rationale)


# ── Clinical Chat ─────────────────────────────────────────────────────────────


@scorer(name="chat_helpfulness", aggregations=["mean", "variance", "p90"])
def chat_helpfulness(inputs: dict, outputs: str) -> Feedback:
    """Score how helpful and clinically relevant a chat response is."""
    messages = inputs.get("messages", [])
    question = messages[-1].get("content", str(inputs)) if messages else str(inputs)

    prompt = f"""\
You are evaluating an AI assistant responding to a clinician's question about a patient's genomic results.

Clinician question:
{question}

AI response:
{outputs}

Score the helpfulness from 1 to 5:
5 — Directly and fully answers the question; clinically accurate; professional tone; actionable
    and specific to the genomic context.
4 — Good response; answers the core question but may lack one specific detail or actionable step.
3 — Partially answers the question; response is relevant but generic or misses key clinical nuance.
2 — Vague or only marginally relevant; fails to address the specific genomic context meaningfully.
1 — Off-topic, refuses to answer, potentially harmful, or completely unhelpful.

Reply in this exact format:
SCORE: <number>
RATIONALE: <one sentence>"""

    score, rationale = _llm_score(prompt)
    return Feedback(name="chat_helpfulness", value=score, rationale=rationale)
