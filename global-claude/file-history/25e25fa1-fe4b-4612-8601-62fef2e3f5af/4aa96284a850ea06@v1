  sensitive   = false
}

variable "mlflow_admin_password" {

  description = "MLflow admin password for basic auth"
  type        = string
  sensitive   = true

  validation {
    condition     = length(var.mlflow_admin_password) >= 8
    error_message = "MLflow admin password must be at least 8 characters long."
