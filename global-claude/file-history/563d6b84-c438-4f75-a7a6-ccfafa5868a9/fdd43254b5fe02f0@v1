[project]
name = "intelxdna-snps-api"
version = "0.0.0"
description = "IntelxDNA SNP's API"
requires-python = ">=3.9"
dependencies = [
    "fastapi[standard]==0.118.2",
    "uvicorn[standard]==0.32.1",
    "motor==3.7.1",
    "pydantic[email]==2.12.0",
    "pydantic-settings==2.5.2",
    "python-dotenv==1.1.1",
    "pymongo==4.10.1",
    "pyjwt==2.8.0",
    "passlib[bcrypt]==1.7.4",
    "python-multipart>=0.0.18",
    "bcrypt==4.1.2",
    "jsonpath-ng==1.7.0",
    "deepdiff>=7.0.0",
    "sqlalchemy[asyncio]==2.0.43",
    "asyncpg==0.30.0",
    "sentry-sdk[fastapi]>=2.0.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=7.0.0",
    "pytest-asyncio>=0.21.0",
    "pytest-env>=1.0.0",
    "pytest-cov>=4.1.0",
    "black>=23.0.0",
    "isort>=5.12.0",
    "httpx>=0.24.0",
    "pre-commit>=3.0.0",
    "flake8>=6.0.0",
    "bandit>=1.7.5",
    "mypy>=1.5.0",
    "pyright>=1.1.390",
    "ruff>=0.15.0",
    "genbadge[coverage]>=1.1.0",
]

[tool.pyright]
pythonVersion = "3.12"
include = ["app"]
typeCheckingMode = "off"
reportMissingImports = "error"
reportMissingModuleSource = "error"

[tool.black]
line-length = 99
target-version = ["py39"]

[tool.isort]
profile = "black"
line_length = 99
multi_line_output = 3
include_trailing_comma = true

[tool.flake8]
max-line-length = 99
extend-ignore = ["E203", "W503"]
exclude = [".git", "__pycache__", "build", "dist"]

[tool.bandit]
exclude_dirs = ["tests"]
skips = ["B101"]

[tool.ruff]
line-length = 99
exclude = [
    ".git",
    "__pycache__",
    "build",
    "dist",
    "migrations",
    "htmlcov",
]

[tool.ruff.lint]
select = [
    "E",    # pycodestyle errors
    "W",    # pycodestyle warnings
    "F",    # pyflakes
    "D",    # pydocstyle (docstrings)
]
ignore = [
    "E203",  # whitespace before ':'
    "D100",  # Missing docstring in public module
    "D104",  # Missing docstring in public package
    "D107",  # Missing docstring in __init__
]

[tool.ruff.lint.pydocstyle]
convention = "google"
