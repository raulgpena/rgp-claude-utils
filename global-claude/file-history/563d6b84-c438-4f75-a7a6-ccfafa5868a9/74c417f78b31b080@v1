[project]
name = "intell-lexxi-backend"
version = "0.0.0"
requires-python = ">=3.12"
description = "IntelxDNA Lexxi API"
dependencies = [
    "fastapi[standard]==0.118.2",
    "uvicorn[standard]==0.32.1",
    "pydantic[email]==2.12.0",
    "pydantic-settings==2.5.2",
    "python-dotenv==1.1.1",
    "pyjwt==2.8.0",
    "passlib[bcrypt]==1.7.4",
    "python-multipart>=0.0.18",
    "bcrypt==4.1.2",
    "pymongo>=4.16.0",
    "openai>=2.18.0",
    "openai-agents>=0.4.2",
    "motor>=3.7.1",
    "reportlab>=4.4.9",
    "pypdf>=5.0.0",
    "python-docx>=1.1.0",
    "sqlalchemy[asyncio]>=2.0.48",
    "asyncpg>=0.31.0",
    "pyctuator==1.2.0",
    "sentry-sdk[fastapi]>=2.0.0",
    "mlflow>=2.14.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
    "pytest-asyncio>=0.21.0",
    "pytest-env>=1.0.0",
    "pytest-cov>=5.0",
    "coverage[toml]>=7.0",
    "black>=23.0.0",
    "isort>=5.12.0",
    "httpx>=0.24.0",
    "pre-commit>=3.0.0",
    "flake8>=6.0.0",
    "bandit>=1.7.5",
    "bandit-sarif-formatter>=1.0.0",
    "genbadge[coverage]>=1.1.0",
    "ruff>=0.15.0",
]

[tool.pytest.ini_options]
testpaths = ["tests"]
asyncio_mode = "auto"
env = [
    "D:SENTRY_DSN=",
]
addopts = [
    "--cov=app",
    "--cov-report=term-missing",
    "--cov-report=xml:coverage.xml",
    "--cov-report=html:coverage-html",
    "--cov-fail-under=80",
]

[tool.coverage.run]
source = ["app"]
omit = [
    "*/migrations/*",
    "*/tests/*",
    "*/__init__.py",
    "*/conftest.py",
    "app/main.py",
]

[tool.coverage.report]
exclude_lines = [
    "pragma: no cover",
    "def __repr__",
    "raise NotImplementedError",
    "if TYPE_CHECKING:",
    "pass",
]

[tool.black]
line-length = 99
target-version = ["py39"]

[tool.isort]
profile = "black"
line_length = 99
multi_line_output = 3
include_trailing_comma = true

[tool.flake8]
max-line-length = 99
extend-ignore = ["E203", "W503"]
exclude = [".git", "__pycache__", "build", "dist"]

[tool.bandit]
exclude_dirs = ["tests"]
skips = ["B101"]

[tool.ruff]
line-length = 99
extend-exclude = ["tests/", "test/"]

[tool.ruff.lint]
select = [
    "D",    # pydocstyle (docstrings only — formatting handled by black)
]

[tool.ruff.lint.pydocstyle]
convention = "google"
