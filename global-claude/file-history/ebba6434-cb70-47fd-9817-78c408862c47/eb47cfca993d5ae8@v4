FROM --platform=linux/amd64 wiremock/wiremock:3.5.4

# Copy all stub mappings into the WireMock mappings directory
COPY mappings /home/wiremock/mappings

# Copy static files served by WireMock (e.g. swagger-ui.html)
COPY __files /home/wiremock/__files

# Start WireMock with response templating enabled (used for dynamic IDs in responses)
CMD ["--global-response-templating", "--verbose", "--port", "8080"]
