<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TargetR API - Mock Documentation</title>
  <link rel="stylesheet" href="https://unpkg.com/swagger-ui-dist@5.17.14/swagger-ui.css" />
  <style>
    body { margin: 0; }
    #swagger-ui .topbar { background-color: #1a237e; }
    #swagger-ui .topbar .download-url-wrapper { display: none; }
  </style>
</head>
<body>
  <div id="swagger-ui"></div>
  <script src="https://unpkg.com/swagger-ui-dist@5.17.14/swagger-ui-bundle.js"></script>
  <script>
    const spec = {
      "openapi": "3.0.3",
      "info": {
        "title": "TargetR API (Mock)",
        "version": "1.0.0",
        "description": "WireMock-based mock of the TargetR API. Base URL via Front Door: `https://api-dev.ixxdna.com/mock`\n\n**Test data:**\n- `pt-001` — Patient-Alpha (female, 1975) → report `rpt-001` (BRCA, completed)\n- `pt-002` — Patient-Beta (male, 1982) → report `rpt-002` (Heart Health, completed)\n- `pt-003` — Patient-Gamma (female, 1968) → report `rpt-003` (Comprehensive, processing)"
      },
      "servers": [
        { "url": "https://api-dev.ixxdna.com/mock", "description": "Dev (via Azure Front Door)" }
      ],
      "tags": [
        { "name": "Patients", "description": "Patient demographics and report listing" },
        { "name": "Reports", "description": "Genomic report metadata and detail" },
        { "name": "Entitlements", "description": "Purchased panel entitlements per report" },
        { "name": "SNPs", "description": "SNP variants per report" },
        { "name": "Artifacts", "description": "Report artifact upload / download" },
        { "name": "Audit Metadata", "description": "Lexxi audit metadata per report" }
      ],
      "paths": {
        "/v1/patients": {
          "get": {
            "tags": ["Patients"],
            "summary": "List all patients",
            "operationId": "listPatients",
            "responses": {
              "200": {
                "description": "Paginated list of patients",
                "content": {
                  "application/json": {
                    "schema": { "$ref": "#/components/schemas/PatientList" },
                    "example": {
                      "items": [
                        { "patientId": "pt-001", "displayName": "Patient-Alpha", "sexAtBirth": "female", "yearOfBirth": 1975 },
                        { "patientId": "pt-002", "displayName": "Patient-Beta",  "sexAtBirth": "male",   "yearOfBirth": 1982 },
                        { "patientId": "pt-003", "displayName": "Patient-Gamma", "sexAtBirth": "female", "yearOfBirth": 1968 }
                      ],
                      "pagination": { "total": 3, "limit": 100, "offset": 0, "hasNext": false }
                    }
                  }
                }
              }
            }
          }
        },
        "/v1/patients/{patientId}": {
          "get": {
            "tags": ["Patients"],
            "summary": "Get patient by ID",
            "operationId": "getPatient",
            "parameters": [
              {
                "name": "patientId",
                "in": "path",
                "required": true,
                "schema": { "type": "string" },
                "description": "Patient identifier (e.g. `pt-001`, `pt-002`, `pt-003`)"
              }
            ],
            "responses": {
              "200": {
                "description": "Patient demographics",
                "content": {
                  "application/json": {
                    "schema": { "$ref": "#/components/schemas/Patient" },
                    "example": {
                      "patientId": "pt-001",
                      "displayName": "Patient-Alpha",
                      "sexAtBirth": "female",
                      "yearOfBirth": 1975,
                      "dateOfBirth": null,
                      "adopted": false,
                      "familyHistoryAvailable": true
                    }
                  }
                }
              },
              "404": { "description": "Patient not found", "content": { "application/json": { "example": { "error": "NOT_FOUND", "message": "Patient not found" } } } }
            }
          }
        },
        "/v1/patients/{patientId}/reports": {
          "get": {
            "tags": ["Patients"],
            "summary": "List reports for a patient",
            "operationId": "listPatientReports",
            "parameters": [
              { "name": "patientId", "in": "path", "required": true, "schema": { "type": "string" } }
            ],
            "responses": {
              "200": {
                "description": "List of report summaries for the patient",
                "content": {
                  "application/json": {
                    "schema": { "$ref": "#/components/schemas/ReportSummaryList" },
                    "example": {
                      "items": [
                        { "reportId": "rpt-001", "patientId": "pt-001", "reportType": "BRCA_ANALYSIS", "status": "COMPLETED", "createdAt": "2024-01-15T10:00:00Z", "completedAt": "2024-01-16T14:30:00Z" }
                      ],
                      "pagination": { "total": 1, "limit": 100, "offset": 0, "hasNext": false }
                    }
                  }
                }
              },
              "404": { "description": "Patient not found" }
            }
          }
        },
        "/v1/reports/{reportId}": {
          "get": {
            "tags": ["Reports"],
            "summary": "Get report by ID",
            "operationId": "getReport",
            "parameters": [
              {
                "name": "reportId",
                "in": "path",
                "required": true,
                "schema": { "type": "string" },
                "description": "Report identifier (e.g. `rpt-001`, `rpt-002`, `rpt-003`)"
              }
            ],
            "responses": {
              "200": {
                "description": "Report metadata and status",
                "content": {
                  "application/json": {
                    "schema": { "$ref": "#/components/schemas/Report" },
                    "example": {
                      "reportId": "rpt-001",
                      "patientId": "pt-001",
                      "reportType": "BRCA_ANALYSIS",
                      "status": "COMPLETED",
                      "riskScore": 0.73,
                      "riskCategory": "HIGH",
                      "createdAt": "2024-01-15T10:00:00Z",
                      "completedAt": "2024-01-16T14:30:00Z",
                      "panelIds": ["BRCA-PANEL-V2"]
                    }
                  }
                }
              },
              "404": { "description": "Report not found" }
            }
          }
        },
        "/v1/reports/{reportId}/entitlements": {
          "get": {
            "tags": ["Entitlements"],
            "summary": "Get entitlements for a report",
            "operationId": "getReportEntitlements",
            "parameters": [
              { "name": "reportId", "in": "path", "required": true, "schema": { "type": "string" } }
            ],
            "responses": {
              "200": {
                "description": "Purchased panels and included panel details",
                "content": {
                  "application/json": {
                    "schema": { "$ref": "#/components/schemas/Entitlements" },
                    "example": {
                      "reportId": "rpt-001",
                      "purchasedPanelIds": ["BRCA-PANEL-V2"],
                      "includedPanels": [
                        { "panelId": "BRCA-PANEL-V2", "panelType": "HEREDITARY_CANCER", "displayName": "BRCA Panel v2", "snpCount": 8 }
                      ]
                    }
                  }
                }
              },
              "409": {
                "description": "Report not yet complete (entitlements unavailable)",
                "content": { "application/json": { "example": { "error": "REPORT_NOT_COMPLETE", "message": "Report is still processing" } } }
              }
            }
          }
        },
        "/v1/reports/{reportId}/snps": {
          "get": {
            "tags": ["SNPs"],
            "summary": "Get SNP variants for a report",
            "operationId": "getReportSnps",
            "parameters": [
              { "name": "reportId", "in": "path", "required": true, "schema": { "type": "string" } }
            ],
            "responses": {
              "200": {
                "description": "Paginated list of SNP variants",
                "content": {
                  "application/json": {
                    "schema": { "$ref": "#/components/schemas/SnpList" },
                    "example": {
                      "items": [
                        {
                          "rsId": "rs80357382",
                          "gene": "BRCA1",
                          "genotype": "AG",
                          "alleleCount": 1,
                          "oddsRatio": 3.84,
                          "genotypeFrequency": 0.002,
                          "panelInclusion": { "panelId": "BRCA-PANEL-V2", "panelType": "HEREDITARY_CANCER" },
                          "tags": ["pathogenic", "clinvar_reviewed"]
                        }
                      ],
                      "pagination": { "total": 8, "limit": 100, "offset": 0, "hasNext": false }
                    }
                  }
                }
              },
              "409": {
                "description": "Report not yet complete",
                "content": { "application/json": { "example": { "error": "REPORT_NOT_COMPLETE", "message": "Report is still processing" } } }
              }
            }
          }
        },
        "/v1/reports/{reportId}/artifacts": {
          "get": {
            "tags": ["Artifacts"],
            "summary": "List artifacts for a report",
            "operationId": "listArtifacts",
            "parameters": [
              { "name": "reportId", "in": "path", "required": true, "schema": { "type": "string" } }
            ],
            "responses": {
              "200": {
                "description": "List of artifacts. Pre-seeded data only for `rpt-001`; all others return empty list.",
                "content": {
                  "application/json": {
                    "schema": { "$ref": "#/components/schemas/ArtifactList" },
                    "example": {
                      "artifacts": [
                        { "artifactId": "art-001", "reportId": "rpt-001", "artifactType": "PDF_REPORT", "fileName": "report.pdf", "contentType": "application/pdf", "sizeBytes": 204800, "uploadedAt": "2024-01-16T15:00:00Z" }
                      ]
                    }
                  }
                }
              }
            }
          },
          "post": {
            "tags": ["Artifacts"],
            "summary": "Upload an artifact for a report",
            "operationId": "uploadArtifact",
            "parameters": [
              { "name": "reportId", "in": "path", "required": true, "schema": { "type": "string" } }
            ],
            "requestBody": {
              "required": true,
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/ArtifactUploadRequest" },
                  "example": {
                    "artifactType": "PDF_REPORT",
                    "fileName": "report.pdf",
                    "contentType": "application/pdf",
                    "sizeBytes": 204800
                  }
                }
              }
            },
            "responses": {
              "201": {
                "description": "Artifact created with dynamically generated ID",
                "content": {
                  "application/json": {
                    "schema": { "$ref": "#/components/schemas/ArtifactUploadResponse" },
                    "example": { "artifactId": "art-abc123", "reportId": "rpt-001", "uploadUrl": "https://storage.example.com/upload/art-abc123" }
                  }
                }
              }
            }
          }
        },
        "/v1/reports/{reportId}/lexxi-metadata": {
          "get": {
            "tags": ["Audit Metadata"],
            "summary": "Get Lexxi audit metadata for a report",
            "operationId": "getLexxiMetadata",
            "parameters": [
              { "name": "reportId", "in": "path", "required": true, "schema": { "type": "string" } }
            ],
            "responses": {
              "200": {
                "description": "Audit metadata. Pre-seeded only for `rpt-001`; all others return 404.",
                "content": {
                  "application/json": {
                    "schema": { "$ref": "#/components/schemas/LexxiMetadata" },
                    "example": {
                      "reportId": "rpt-001",
                      "reviewedBy": "lexxi-user-001",
                      "reviewedAt": "2024-01-17T09:00:00Z",
                      "auditNotes": "Reviewed and approved",
                      "tags": ["approved"]
                    }
                  }
                }
              },
              "404": { "description": "No metadata found for this report" }
            }
          },
          "post": {
            "tags": ["Audit Metadata"],
            "summary": "Submit Lexxi audit metadata for a report",
            "operationId": "submitLexxiMetadata",
            "parameters": [
              { "name": "reportId", "in": "path", "required": true, "schema": { "type": "string" } }
            ],
            "requestBody": {
              "required": true,
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/LexxiMetadataRequest" },
                  "example": {
                    "reviewedBy": "lexxi-user-001",
                    "auditNotes": "Reviewed and approved",
                    "tags": ["approved"]
                  }
                }
              }
            },
            "responses": {
              "200": {
                "description": "Metadata submitted successfully",
                "content": { "application/json": { "example": { "success": true } } }
              }
            }
          }
        }
      },
      "components": {
        "schemas": {
          "Patient": {
            "type": "object",
            "properties": {
              "patientId":              { "type": "string" },
              "displayName":            { "type": "string" },
              "sexAtBirth":             { "type": "string", "enum": ["male", "female", "unknown"] },
              "yearOfBirth":            { "type": "integer", "nullable": true },
              "dateOfBirth":            { "type": "string", "format": "date", "nullable": true },
              "adopted":                { "type": "boolean" },
              "familyHistoryAvailable": { "type": "boolean", "nullable": true }
            }
          },
          "PatientList": {
            "type": "object",
            "properties": {
              "items":      { "type": "array", "items": { "$ref": "#/components/schemas/Patient" } },
              "pagination": { "$ref": "#/components/schemas/Pagination" }
            }
          },
          "ReportSummary": {
            "type": "object",
            "properties": {
              "reportId":    { "type": "string" },
              "patientId":   { "type": "string" },
              "reportType":  { "type": "string" },
              "status":      { "type": "string", "enum": ["PENDING", "PROCESSING", "COMPLETED", "FAILED"] },
              "createdAt":   { "type": "string", "format": "date-time" },
              "completedAt": { "type": "string", "format": "date-time", "nullable": true }
            }
          },
          "ReportSummaryList": {
            "type": "object",
            "properties": {
              "items":      { "type": "array", "items": { "$ref": "#/components/schemas/ReportSummary" } },
              "pagination": { "$ref": "#/components/schemas/Pagination" }
            }
          },
          "Report": {
            "allOf": [
              { "$ref": "#/components/schemas/ReportSummary" },
              {
                "type": "object",
                "properties": {
                  "riskScore":    { "type": "number", "nullable": true },
                  "riskCategory": { "type": "string", "nullable": true },
                  "panelIds":     { "type": "array", "items": { "type": "string" } }
                }
              }
            ]
          },
          "PanelDetail": {
            "type": "object",
            "properties": {
              "panelId":     { "type": "string" },
              "panelType":   { "type": "string" },
              "displayName": { "type": "string" },
              "snpCount":    { "type": "integer" }
            }
          },
          "Entitlements": {
            "type": "object",
            "properties": {
              "reportId":          { "type": "string" },
              "purchasedPanelIds": { "type": "array", "items": { "type": "string" } },
              "includedPanels":    { "type": "array", "items": { "$ref": "#/components/schemas/PanelDetail" } }
            }
          },
          "PanelInclusion": {
            "type": "object",
            "properties": {
              "panelId":   { "type": "string" },
              "panelType": { "type": "string" }
            }
          },
          "Snp": {
            "type": "object",
            "properties": {
              "rsId":               { "type": "string" },
              "gene":               { "type": "string" },
              "genotype":           { "type": "string" },
              "alleleCount":        { "type": "integer", "nullable": true },
              "oddsRatio":          { "type": "number" },
              "genotypeFrequency":  { "type": "number" },
              "panelInclusion":     { "$ref": "#/components/schemas/PanelInclusion" },
              "tags":               { "type": "array", "items": { "type": "string" } }
            }
          },
          "SnpList": {
            "type": "object",
            "properties": {
              "items":      { "type": "array", "items": { "$ref": "#/components/schemas/Snp" } },
              "pagination": { "$ref": "#/components/schemas/Pagination" }
            }
          },
          "Artifact": {
            "type": "object",
            "properties": {
              "artifactId":   { "type": "string" },
              "reportId":     { "type": "string" },
              "artifactType": { "type": "string" },
              "fileName":     { "type": "string" },
              "contentType":  { "type": "string" },
              "sizeBytes":    { "type": "integer" },
              "uploadedAt":   { "type": "string", "format": "date-time" }
            }
          },
          "ArtifactList": {
            "type": "object",
            "properties": {
              "artifacts": { "type": "array", "items": { "$ref": "#/components/schemas/Artifact" } }
            }
          },
          "ArtifactUploadRequest": {
            "type": "object",
            "required": ["artifactType", "fileName", "contentType"],
            "properties": {
              "artifactType": { "type": "string" },
              "fileName":     { "type": "string" },
              "contentType":  { "type": "string" },
              "sizeBytes":    { "type": "integer" }
            }
          },
          "ArtifactUploadResponse": {
            "type": "object",
            "properties": {
              "artifactId": { "type": "string" },
              "reportId":   { "type": "string" },
              "uploadUrl":  { "type": "string" }
            }
          },
          "LexxiMetadata": {
            "type": "object",
            "properties": {
              "reportId":   { "type": "string" },
              "reviewedBy": { "type": "string" },
              "reviewedAt": { "type": "string", "format": "date-time" },
              "auditNotes": { "type": "string" },
              "tags":       { "type": "array", "items": { "type": "string" } }
            }
          },
          "LexxiMetadataRequest": {
            "type": "object",
            "required": ["reviewedBy"],
            "properties": {
              "reviewedBy": { "type": "string" },
              "auditNotes": { "type": "string" },
              "tags":       { "type": "array", "items": { "type": "string" } }
            }
          },
          "Pagination": {
            "type": "object",
            "properties": {
              "total":   { "type": "integer" },
              "limit":   { "type": "integer" },
              "offset":  { "type": "integer" },
              "hasNext": { "type": "boolean" }
            }
          }
        }
      }
    };

    window.onload = () => {
      SwaggerUIBundle({
        spec,
        dom_id: '#swagger-ui',
        presets: [SwaggerUIBundle.presets.apis, SwaggerUIBundle.SwaggerUIStandalonePreset],
        layout: 'BaseLayout',
        deepLinking: true,
        tryItOutEnabled: true,
        requestInterceptor: (req) => {
          // Strip /mock prefix added by Front Door on try-it-out requests
          req.url = req.url.replace(/^(https?:\/\/[^/]+)\/mock\/v1/, '$1/mock/v1');
          return req;
        }
      });
    };
  </script>
</body>
</html>
