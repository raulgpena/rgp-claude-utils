{
  "id": "a1000020-0000-0000-0000-000000000001",
  "name": "POST /v1/reports/{reportId}/artifacts",
  "request": {
    "method": "POST",
    "urlPathPattern": "/v1/reports/[^/]+/artifacts"
  },
  "response": {
    "status": 201,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "artifactId": "art-{{randomValue type='UUID'}}",
